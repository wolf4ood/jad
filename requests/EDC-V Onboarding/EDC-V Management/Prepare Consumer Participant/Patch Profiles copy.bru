meta {
  name: Patch Profiles copy
  type: http
  seq: 12
}

put {
  url: {{cpBaseUrl}}/v5beta/participants/{{consumer_id}}/profiles
  body: json
  auth: inherit
}

body:json {
  {
    "@context": [
      "https://w3id.org/edc/connector/management/v2"
    ],
    "@type": "AssociateDataspaceProfile",
    "profiles": ["cx-neptune"]
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
