meta {
  name: Prepare Dataplane
  type: http
  seq: 4
}

put {
  url: {{cpBaseUrl}}/v5beta/participants/{{provider_id}}/dataplanes
  body: json
  auth: inherit
}

body:json {
  {
    "id": "provider-siglet",
    "transferTypes": [
      "HttpData-PULL"
    ],
    "endpoint": "http://siglet.edc-v.svc.cluster.local:8081/api/v1/{{provider_id}}/dataflows"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
