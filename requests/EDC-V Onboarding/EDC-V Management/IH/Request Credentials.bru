meta {
  name: Request Credentials
  type: http
  seq: 3
}

post {
  url: {{identityHubUrl}}/participants/{{tx_provider_context_id}}/credentials/request
  body: json
  auth: inherit
}

body:json {
  {
    "issuerDid": "did:web:issuerservice.edc-v.svc.cluster.local%3A10016:issuer",
    "holderPid": "gov-pid-2",
    "credentials": [
      {
        "id": "gov-credential-def",
        "type": "DataExchangeGovernanceCredential",
        "format": "VC1_0_JWT"
      }
    ]
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
