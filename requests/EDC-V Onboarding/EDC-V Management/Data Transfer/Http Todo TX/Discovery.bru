meta {
  name: Discovery
  type: http
  seq: 1
}

post {
  url: {{cpBaseUrl}}/v5beta/participants/{{consumer_id}}/discover/request
  body: json
  auth: inherit
}

body:json {
  {
    "@context": [
      "https://w3id.org/edc/connector/management/v2"
    ],
    "@type": "DiscoveryRequest",
    "counterPartyAddress": "http://tx-connector.edc-v.svc.cluster.local:8082/api/dsp/.well-known/dspace-version"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
