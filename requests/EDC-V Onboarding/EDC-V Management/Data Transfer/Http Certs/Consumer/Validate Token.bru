meta {
  name: Validate Token
  type: http
  seq: 8
}

post {
  url: {{sigletBaseUrl}}/tokens/verify
  body: json
  auth: inherit
}

body:json {
  {
    "token": "eyJhbGciOiJFZERTQSIsImtpZCI6InNpZ2xldC1pc3N1ZXIjc2lnbmluZy1zaWdsZXQtMSIsInR5cCI6IkpXVCJ9..YI4AlXgD7-B9i39ILyXjngxL6yc4UIyEi24T_RErmvdNweujP_vq0D5ia5WwkwlysCvmT4YxAIfnOe-W4RSYDA",
    "audience": "test"
  }
}

script:post-response {
  try {
      const json = res.getBody();
      const accessToken = json['token'];
    
      if (accessToken && typeof accessToken === 'string') {
          bru.setVar('ACCESS_TOKEN', accessToken);
      } else {
          console.warn('Access Token not found');
      }
  
  } catch (e) {
      console.error('Failed to parse response or set Access Token:', e);
      test('Response is valid JSON', function () {
          throw e;
      });
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
