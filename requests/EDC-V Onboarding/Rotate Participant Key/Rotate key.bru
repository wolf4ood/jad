meta {
  name: Rotate key
  type: http
  seq: 5
}

post {
  url: {{identityHubUrl}}/participants/{{tx_provider_context_id}}/keypairs/{{active_key_id}}/rotate
  body: json
  auth: inherit
}

body:json {
  {
    "keyGeneratorParams": {
      "algorithm": "eddsa",
      "curve": "ed25519"    
    },
    "keyId": "{{tx_provider_context_id}}#{{$randomUUID}}",
    "privateKeyAlias": "{{$randomUUID}}" 
  }
  
}

settings {
  encodeUrl: true
  timeout: 0
  followRedirects: true
  maxRedirects: 5
}
